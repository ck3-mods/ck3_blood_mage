# Copy this file to .env and restrict it with chmod 600.

# Workshop target: CK3's app ID is stable; set the item ID to remote_file_id.
STEAM_APP_ID=1158310
STEAM_PUBLISHED_FILE_ID=

# Steam account
STEAM_USERNAME=
STEAM_PASSWORD=
# auto uses steamguard-cli when configured; use disabled for an account without Steam Guard.
STEAM_GUARD=auto
